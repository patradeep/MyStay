<% layout('layouts/boilerplate') %>
<body>

    <div class="row ">
        <div class="col col-md-6 offset-md-2">
            <div class="card">
                <h4 class="card-title mb-3 mt-3"><%= list.title %></h4>
                <img src="<%= list.image %>" class="card-img-top" alt="Place image">
                <div class="card-body">
                    <p><i class="fas fa-user"></i> <b><%= list.owner.username %></b></p>
                    <p><b>Price: &#8377;<%= list.price.toLocaleString("en-IN") %></b></p>
                    <p class="card-text"><%= list.description %>.</p>
                    <p>Location: <%= list.location %></p>
                    <p>Country: <%= list.country %></p>
                    <% if(currentUser && currentUser._id.equals(list.owner._id)){ %>
                    <div class="row">
                        <div class="col">
                            <form method="POST" action="/listing/<%= list.id %>?_method=DELETE">
                                <button class="btn btn-danger" type="submit">Delete Listing</button>
                            </form>
                        </div>
                        <div class="col">
                            <a href="/listing/<%= list.id %>/edit" class="btn btn-secondary">Edit Listing</a>
                        </div>
                    </div>
                    <% } %>
                    <hr>
                    <% if(currentUser){ %>
                    <div class="row mt-3">
                        <div class="col">
                            <form method="post" action="/listing/<%=list.id%>/review">
                                <div class="mb-3">
                                    <label for="rating" class="form-label">Rating:</label>
                                    <select class="form-control" id="rating" name="rating" required>
                                        <option value="">Select a rating</option>
                                        <option value="1">1</option>
                                        <option value="2">2</option>
                                        <option value="3">3</option>
                                        <option value="4">4</option>
                                        <option value="5">5</option>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label for="comment" class="form-label">Add a comment:</label>
                                    <textarea class="form-control" id="comment" name="comment" rows="3" required></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary">Submit Review</button>
                            </form>
                        </div>
                </div>
                <% } else { %>
                    <p><a href="/login">Log in</a> to add a review.</p>
                <% } %>
            </div>
        </div>
    </div>

    <hr>

    <div class="row mt-4">
        <div class="col col-md-8 offset-md-2">
            <h3>Reviews:</h3>
            <% if(list.reviews.length === 0){ %>
                <p>No reviews yet.</p>
            <% } else { %>
                <% list.reviews.forEach(review => { %>
                    <div class="card mb-3">
                        <div class="card-body">
                            <p><i class="fas fa-user"></i> <b><%= review.author.username %></b></p>
                            <h5 class="card-title">Rating: <%= review.rating %> / 5</h5>
                            <p class="card-text"><%= review.comment %></p>
                        </div>
                        <% if(currentUser && review.author._id.equals(currentUser._id)){ %>
                        <form method="POST" action="/listing/<%=list.id%>/review/<%=review.id%>?_method=DELETE">
                            <button class="btn btn-danger" type="submit">Delete Review</button>
                        </form>
                        <% } %>
                    </div>
                <% }); %>
            <% } %>
        </div>

    </div>
    

</body>
