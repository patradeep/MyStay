<% layout('layouts/boilerplate') %>
<body>
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h3 class="mb-4">Update Listing</h3>
            <form method="POST" action="/listing/<%= list.id %>?_method=PUT" enctype="multipart/form-data">
                <div class="mb-3">
                    <label class="form-label" for="title">Title:</label>
                    <input class="form-control" type="text" id="title" name="title" value="<%= list.title %>" required>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="description">Description:</label>
                    <textarea class="form-control" id="description" name="description" required><%= list.description %></textarea>
                </div>

                <div>
                    <p>Current Image:</p>
                    <img src="<%= imageUrl %>" alt="Current Image" class="mb-3">
                </div>

                <div class="mb-3">
                    <label class="form-label" for="image">Update Image:</label>
                    <input class="form-control" type="file" id="image" name="image" accept="image/*">
                </div>

                <div class="row">
                    <div class="mb-3 col-md-4">
                    <label class="form-label" for="price">Price:</label>
                    <input class="form-control" type="number" id="price" name="price" value="<%= list.price %>" required>
                </div>

                    <div class="mb-3 col-md-8">
                    <label class="form-label" for="country">Country:</label>
                    <input class="form-control" type="text" id="country" name="country" value="<%= list.country %>" required>
                </div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="location">Location:</label>
                    <input class="form-control" type="text" id="location" name="location" value="<%= list.location %>" required>
                </div>

                <button class="btn btn-primary" type="submit">Update Listing</button>
            </form>
        </div>
    </div>
    
</body>
